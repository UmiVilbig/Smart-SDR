# Copy this file to .env and fill in your values

# Claude API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Twilio credentials (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX   # your Twilio phone number

# Your phone number to receive SMS (E.164 format)
SMS_TO_NUMBER=+1XXXXXXXXXX

# RTL-SDR API base URL (change if running API on a different host/port)
SDR_API_BASE=http://localhost:8000
